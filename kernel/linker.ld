ENTRY(_start)

SECTIONS
{
    . = DEFINED(RYMOS_LOAD_ADDR) ? RYMOS_LOAD_ADDR : 1M;

    .text : ALIGN(4K) {
        *(.text .text.*)
    }

    .rodata : ALIGN(4K) {
        *(.rodata .rodata.*)
    }

    .data : ALIGN(4K) {
        *(.data .data.*)
    }

    .bss : ALIGN(4K) {
        *(COMMON)
        *(.bss .bss.*)
    }
}
